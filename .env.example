# Survey Builder Frontend — environment template
#
# Copy this file to `.env` (same directory) before running `npm start`,
# `npm run build`, or `npx playwright test`. The CRA build inlines
# REACT_APP_* values at BUILD TIME — they must be present BEFORE the
# build runs, not after.
#
# `.env` itself is in .gitignore (along with the smoke/ scratch dir).
# Phase 12 of the design migration discovered the file had been
# silently deleted between phases, which made the production build
# render the "Google sign-in is not configured" page and broke every
# authenticated route + E2E spec. This template exists so that state
# can be recovered in one copy.
#
# ─── Why these REACT_APP_* values are safe to commit in template form
# REACT_APP_SUPABASE_ANON_KEY is the *anon* (public) Supabase key. It
# is *meant* to ship to clients — Row Level Security on the backend is
# the canonical authorisation boundary. Treat it like a public CDN
# URL, not a secret. The service-role key (which IS a secret) lives
# only on the Survey-builder-BE backend and is NEVER referenced by
# any REACT_APP_* var.

# ─── REQUIRED ──────────────────────────────────────────────────────
# Supabase project URL. Format: https://<project-ref>.supabase.co
# The project-ref is also embedded in the localStorage session key
# Supabase v2 uses (`sb-<project-ref>-auth-token`), and e2e/fixtures.js
# derives that key from this URL at test time.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase *anon* key (public, safe to ship to clients).
# Get it from the Supabase dashboard → Settings → API → "anon public".
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-jwt-here

# ─── OPTIONAL ──────────────────────────────────────────────────────
# Surface the legacy username/password login row on the Login screen.
# Set to "true" during the Google-auth migration window so existing
# legacy users can still sign in. Defaults to off when unset.
REACT_APP_LEGACY_LOGIN_VISIBLE=true

# Feature flag for the Publish/Unpublish controls on QuestionList.
# Set to "true" to enable; defaults to off when unset. Useful for
# staging environments where the publish flow is being trialled.
REACT_APP_FEATURE_PUBLISH=false
