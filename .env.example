# Copy to `.env.local` for local dev (CRA reads .env.local, gitignored).
# For Vercel: set these as Project Environment Variables.

REACT_APP_SUPABASE_URL=https://<your-project-ref>.supabase.co
REACT_APP_SUPABASE_ANON_KEY=<your supabase anon public key>

# Optional — show the Publish / Unpublish buttons in the question master
# REACT_APP_FEATURE_PUBLISH=true
